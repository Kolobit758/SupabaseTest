<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Game Hub</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <style>
      body {
        background: #080810;
        color: white;
        font-family: Arial;
      }

      .hero {
        padding: 80px 20px;
        text-align: center;
      }

      .hero h1 {
        font-size: 60px;
        font-weight: bold;
        color: #e8ff47;
      }

      .game-grid {
        max-width: 1100px;
        margin: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
        padding: 30px;
      }

      .card-game {
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s;
      }

      .card-game:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
      }

      .card-game img {
        width: 100%;
        height: 180px;
        object-fit: cover;
      }

      .card-body {
        padding: 20px;
      }

      .card-body h3 {
        color: #e8ff47;
        font-size: 24px;
      }

      .play-btn {
        width: 100%;
        margin-top: 15px;
        background: #e8ff47;
        border: none;
        padding: 12px;
        font-weight: bold;
        border-radius: 12px;
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-dark bg-dark px-3">
      <a class="navbar-brand text-warning" href="index.html">🎓 Students</a>
      <a class="btn btn-outline-light btn-sm" href="games.html">Home</a>
    </nav>

    <section class="hero">
      <h1>🎮 GAME HUB</h1>
      <p>รวมเกมทั้งหมดของระบบ</p>
    </section>

    <div class="game-grid">
      <div class="card-game">
        <img src="snake-preview.jpg" />
        <div class="card-body">
          <h3>🐍 Snake</h3>
          <p>เกมงูสุดคลาสสิค</p>
          <a href="super_snake.html">
            <button class="play-btn">▶ เล่นเกม</button>
          </a>
        </div>
      </div>

      <div class="card-game">
        <img src="bird-preview.jpg" />
        <div class="card-body">
          <h3>🐤 Flappy Bird</h3>
          <p>หลบท่อให้ได้คะแนนสูงสุด</p>
          <a href="flappy.html">
            <button class="play-btn">▶ เล่นเกม</button>
          </a>
        </div>
      </div>

      <div class="card-game">
        <img src="fourth-preview.jpg" />
        <div class="card-body">
          <h3>🔥 Fourth Game</h3>
          <p>เกมลับของคุณ</p>
          <a href="Fourth.html">
            <button class="play-btn">▶ เล่นเกม</button>
          </a>
        </div>
      </div>
      <div class="card-game">
        <img src="fourth-preview.jpg" />
        <div class="card-body">
          <h3>🔥 super_snake Game</h3>
          <p>เกมลับของคุณ</p>
          <a href="super_snake.html">
            <button class="play-btn">▶ เล่นเกม</button>
          </a>
        </div>
      </div>
      <div class="card-game">
        <img src="fourth-preview.jpg" />
        <div class="card-body">
          <h3>🔥 rhythm Game</h3>
          <p>เกมลับของคุณ</p>
          <a href="rhythm.html">
            <button class="play-btn">▶ เล่นเกม</button>
          </a>
        </div>
      </div>
    </div>
  </body>
